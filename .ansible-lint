---
# ansible-lint configuration - uses profile-based system
# Available profiles: min, basic, moderate, safety, shared, production
# See: https://docs.ansible.com/projects/lint/profiles/
profile: production

exclude_paths:
  - .git
  - .venv
  - venv
  # SOPS-encrypted files are opaque ciphertext + metadata; linting is meaningless.
  # Recursive glob matches the `.sops.yaml` rule (`\.enc\.ya?ml$`)
  # and catches encrypted files in any subdirectory.
  - "**/*.enc.yaml"
  - "**/*.enc.yml"
  # Galaxy-installed shared role (gitignored, third-party code) — linted in
  # its home repo (dryvist/homelab-contracts), not here.
  - roles/inventory_resolve

# File type overrides - tell linter the correct type for files in non-standard locations
kinds:
  - playbook: "**/load_tofu.yml"

# Roles provided by the sibling ansible-proxmox-apps repo at deploy time.
# The AI Docker roles declare a meta dependency on docker_engine (shared
# bootstrap role that stays in apps); mock_roles makes the dependency
# resolvable for syntax-check without vendoring a duplicate copy here.
mock_roles:
  - docker_engine
