{{ ansible_managed | comment }}
# OpenBao AppRole credential for the ai-public domain (read-only on
# ai/public/*), consumed ONLY by open-webui-brain-sync.service. Root-only
# (0600), separate from /etc/open-webui.env by design (see defaults/main.yml).
AI_PUBLIC_VAULT_ROLE_ID={{ open_webui_brain_sync_role_id }}
AI_PUBLIC_VAULT_SECRET_ID={{ open_webui_brain_sync_secret_id }}
