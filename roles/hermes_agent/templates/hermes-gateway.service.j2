{{ ansible_managed | comment }}
[Unit]
Description=Hermes Agent gateway (autonomous agent daemon + cron + Kanban dispatcher)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ hermes_agent_user }}
Group={{ hermes_agent_user }}
# cwd MUST be $HERMES_HOME, not its parent: the gateway's hindsight memory
# plugin resolves `.env` (and other profile files) RELATIVE to cwd — from the
# parent dir its local-runtime check fails and every memory call reports
# "Memory is not available".
WorkingDirectory={{ hermes_agent_hermes_home }}
Environment=HERMES_HOME={{ hermes_agent_hermes_home }}
# Load the deployed secrets so config.yaml's ${VAR} interpolation resolves. The
# leading '-' keeps the daemon startable while .env is still empty (no messaging
# platform wired yet) — the LiteLLM router master key still arrives via this file.
EnvironmentFile=-{{ hermes_agent_hermes_home }}/.env
ExecStart={{ hermes_agent_gateway_cmd }}
# gateway is a queue-driven 24/7 dispatcher — a clean exit is still an outage,
# so Restart=always lives in the unit itself. This repo's site.yml has no
# systemd_restart_policy phase (tracked in the repo issue about dead
# restart-policy group_vars).
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target
