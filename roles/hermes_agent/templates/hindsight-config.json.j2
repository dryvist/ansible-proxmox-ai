{% if hermes_agent_memory_mode == 'local_external' %}
{
  "_comment": {{ (ansible_managed + " — hindsight memory provider (local_external): the standalone HA Hindsight service behind the Traefik pool. Extraction LLM/embeddings are server-side config.") | to_json }},
  "mode": "local_external",
  "api_url": {{ hermes_agent_memory_api_url | mandatory('hermes_agent_memory_api_url must be set in local_external mode') | to_json }}
}
{% else %}
{
  "_comment": {{ (ansible_managed + " — hindsight memory provider (mode + embedded-daemon LLM). Secrets stay in .env (HINDSIGHT_LLM_API_KEY).") | to_json }},
  "mode": {{ hermes_agent_memory_mode | to_json }},
  "llm_provider": "openai_compatible",
  "llm_base_url": {{ hermes_agent_model_base_url | to_json }},
  "llm_model": {{ hermes_agent_memory_llm_model | to_json }}
}
{% endif %}
