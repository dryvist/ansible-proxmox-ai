{{ ansible_managed | comment }}
# OpenBao AppRole credential for the ai-public domain (read-only on
# ai/public/*), consumed ONLY by hermes-brain-sync.service — never by the
# hermes user's own gateway process. Root-only (0600), separate from
# {{ hermes_agent_hermes_home }}/.env by design (see defaults/main.yml).
AI_PUBLIC_VAULT_ROLE_ID={{ hermes_agent_brain_sync_role_id }}
AI_PUBLIC_VAULT_SECRET_ID={{ hermes_agent_brain_sync_secret_id }}
