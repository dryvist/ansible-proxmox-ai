# {{ ansible_managed }}
# Ship all Hermes logs to the hermes_agent AI ingest listener:
#   journald (every hermes-* unit, including differently tagged child processes)
#   + {{ hermes_agent_log_directory }}/*.log
#   -> {{ hermes_agent_syslog_host }}:{{ hermes_agent_syslog_port }} (tcp)
#   -> HAProxy -> Cribl Stream (ai_stamp) -> Splunk index=hermes.
#
# rsyslog ingests the journal by default on Debian, so every hermes-* unit's
# lines arrive on the default ruleset. Child processes can use another
# programname (for example sudo), so the unit field is part of the match. The
# DEDICATED ruleset forwards those lines and `stop`s them, so they never also hit a
# syslog_forwarder catch-all and double-ship into the os index. (The `stop`
# also keeps hermes lines out of local /var/log/syslog — journald still retains
# them, and index=hermes is the search surface.) This drop-in is numbered 05-
# so it is evaluated before any 10-forward-cribl.conf catch-all.

ruleset(name="hermes_agent") {
  action(type="omfwd"
         target="{{ hermes_agent_syslog_host }}"
         port="{{ hermes_agent_syslog_port }}"
         protocol="tcp"
         queue.type="LinkedList"
         queue.filename="hermes_agent_fwd"
         queue.maxDiskSpace="{{ hermes_agent_syslog_queue_max_disk_space }}"
         queue.saveOnShutdown="on"
         action.resumeRetryCount="-1")
  stop
}

module(load="imfile")

input(type="imfile"
      File="{{ hermes_agent_log_directory }}/*.log"
      Tag="hermes-file"
      PersistStateInterval="100"
      freshStartTail="off"
      Ruleset="hermes_agent")

if ($programname startswith 'hermes' or $!_SYSTEMD_UNIT startswith 'hermes-') then {
  call hermes_agent
}
