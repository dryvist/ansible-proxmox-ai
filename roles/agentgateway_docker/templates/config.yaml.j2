# {{ ansible_managed }}
# agentgateway static config — regenerated on every converge (config as code).
# Schema: https://agentgateway.dev/schema/config
#
# One route PER target (path-scoped, e.g. /splunk) instead of one
# multiplexed route: auth is passthrough, and a shared route would forward a
# caller's Authorization header to EVERY backend a tool resolves to — leaking
# the Splunk token to external targets. Path isolation keeps each credential
# on its own backend; clients configure one MCP server entry per path.
#
# Route naming: the vhost is already mcp.<sub>, so the path is just the
# capability name (/splunk, /context7, /memory, /docs, /hindsight) — the
# /mcp suffix carried no protocol meaning (Streamable HTTP POSTs to whatever
# URL the client is given). The transitional /<name>/mcp aliases were
# removed once Hermes and the workstation client configs migrated (#22).
config:
  # Bind the admin UI (Traefik-fronted) and the stats server (Prometheus
  # /metrics) on all interfaces so the LXC can publish them; the guest
  # firewall scopes both internal-only. Ports are DRY from pipeline_constants.
  adminAddr: "0.0.0.0:{{ agentgateway_docker_admin_port }}"
  statsAddr: "0.0.0.0:{{ agentgateway_docker_metrics_port }}"
  tracing:
    # OTLP/HTTP to the shared Cribl Edge receiver; Cribl forks to
    # Langfuse + Splunk (no direct exporters — telemetry always via Cribl).
    otlpEndpoint: "{{ agentgateway_docker_otlp_endpoint }}"
    otlpProtocol: http
    randomSampling: {{ agentgateway_docker_trace_sampling }}

binds:
- port: {{ agentgateway_docker_proxy_port }}
  listeners:
  - routes:
{% for target in agentgateway_docker_mcp_targets %}
    - matches:
      - path:
          exact: /{{ target.name }}
      backends:
      - mcp:
          targets:
          - name: {{ target.name }}
            mcp:
              host: {{ target.host }}
{% if target.tls_insecure | default(false) %}
            policies:
              backendTLS:
                insecure: true
{% endif %}
{% endfor %}
{% if agentgateway_docker_qdrant_mcp_enabled | bool
      and agentgateway_docker_qdrant_api_key | length > 0 %}
{# Vector-memory MCP (capability route /memory) — backend is the
   mcp-server-qdrant sidecar in this compose stack (service name on the
   compose network, no host port). Trailing slash on the backend path is
   REQUIRED: FastMCP 307-redirects /mcp -> /mcp/, and the redirect escaped
   the route (the live /qdrant/mcp dead-end in #22). #}
    - matches:
      - path:
          exact: /memory
      backends:
      - mcp:
          targets:
          - name: memory
            mcp:
              host: http://mcp-qdrant:{{ agentgateway_docker_qdrant_mcp_port }}/mcp/
{% if agentgateway_docker_docs_mcp_enabled | bool %}
{# Docs-search MCP (capability route /docs) — read-only sidecar over the
   llamaindex homelab_docs collection. Same trailing-slash rule as /memory. #}
    - matches:
      - path:
          exact: /docs
      backends:
      - mcp:
          targets:
          - name: docs
            mcp:
              host: http://mcp-docs:{{ agentgateway_docker_docs_mcp_port }}/mcp/
{% endif %}
{% endif %}
{% for target in agentgateway_docker_a2a_targets | default([]) %}
    - matches:
      - path:
          pathPrefix: {{ target.path_prefix }}
      policies:
        a2a: {}
      backends:
      - host: {{ target.host }}
{% endfor %}
