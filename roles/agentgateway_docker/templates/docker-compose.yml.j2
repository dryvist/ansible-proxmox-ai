# {{ ansible_managed }}
services:
  agentgateway:
    image: {{ agentgateway_docker_image }}
    container_name: {{ agentgateway_docker_container_name }}
    restart: {{ agentgateway_docker_restart_policy }}
    command: ["-f", "/config.yaml"]
    ports:
      - "{{ agentgateway_docker_proxy_port }}:{{ agentgateway_docker_proxy_port }}"
      - "{{ agentgateway_docker_admin_port }}:{{ agentgateway_docker_admin_port }}"
      - "{{ agentgateway_docker_metrics_port }}:{{ agentgateway_docker_metrics_port }}"
    volumes:
      - "{{ agentgateway_docker_data_dir }}/config.yaml:/config.yaml:ro"
{% if agentgateway_docker_qdrant_mcp_enabled | bool
      and agentgateway_docker_qdrant_api_key | length > 0 %}

  # Qdrant vector-memory MCP sidecar (see defaults). Reached only by the
  # gateway over the compose network — no host port published.
  mcp-qdrant:
    image: {{ agentgateway_docker_qdrant_mcp_image }}
    container_name: mcp-qdrant
    restart: {{ agentgateway_docker_restart_policy }}
    entrypoint: ["uvx"]
    command:
      - "mcp-server-qdrant=={{ agentgateway_docker_qdrant_mcp_version }}"
      - "--transport"
      - "streamable-http"
    environment:
      FASTMCP_SERVER_HOST: "0.0.0.0"
      FASTMCP_SERVER_PORT: "{{ agentgateway_docker_qdrant_mcp_port }}"
      QDRANT_URL: "{{ agentgateway_docker_qdrant_url }}"
      QDRANT_API_KEY: "{{ agentgateway_docker_qdrant_api_key }}"
      COLLECTION_NAME: "{{ agentgateway_docker_qdrant_mcp_collection }}"
    volumes:
      # Cache the uvx-resolved package + fastembed model across restarts.
      - mcp_qdrant_cache:/root/.cache
{% if agentgateway_docker_docs_mcp_enabled | bool %}

  # Docs-search MCP sidecar (see defaults) — read-only mcp-server-qdrant over
  # llamaindex's docs collection. Same image/version pins as mcp-qdrant.
  mcp-docs:
    image: {{ agentgateway_docker_qdrant_mcp_image }}
    container_name: mcp-docs
    restart: {{ agentgateway_docker_restart_policy }}
    entrypoint: ["uvx"]
    command:
      - "mcp-server-qdrant=={{ agentgateway_docker_qdrant_mcp_version }}"
      - "--transport"
      - "streamable-http"
    environment:
      FASTMCP_SERVER_HOST: "0.0.0.0"
      FASTMCP_SERVER_PORT: "{{ agentgateway_docker_docs_mcp_port }}"
      QDRANT_URL: "{{ agentgateway_docker_qdrant_url }}"
      QDRANT_API_KEY: "{{ agentgateway_docker_qdrant_api_key }}"
      QDRANT_READ_ONLY: "true"
      COLLECTION_NAME: "{{ agentgateway_docker_docs_mcp_collection }}"
      EMBEDDING_MODEL: "{{ agentgateway_docker_docs_mcp_embedding_model }}"
      TOOL_FIND_DESCRIPTION: "{{ agentgateway_docker_docs_mcp_find_description }}"
    volumes:
      - mcp_qdrant_cache:/root/.cache
{% endif %}

volumes:
  mcp_qdrant_cache:
{% endif %}
