# {{ ansible_managed }}
services:
  agentgateway:
    image: {{ agentgateway_docker_image }}
    container_name: {{ agentgateway_docker_container_name }}
    restart: {{ agentgateway_docker_restart_policy }}
    command: ["-f", "/config.yaml"]
    ports:
      - "{{ agentgateway_docker_proxy_port }}:{{ agentgateway_docker_proxy_port }}"
      - "{{ agentgateway_docker_admin_port }}:{{ agentgateway_docker_admin_port }}"
      - "{{ agentgateway_docker_metrics_port }}:{{ agentgateway_docker_metrics_port }}"
    volumes:
      - "{{ agentgateway_docker_data_dir }}/config.yaml:/config.yaml:ro"
{% if agentgateway_docker_vikunja_mcp_enabled | bool
      and agentgateway_docker_vikunja_read_token | length > 0 %}

  # Vikunja MCP sidecar (see defaults). supergateway wraps the stdio-only
  # vikunja-mcp into Streamable HTTP; reached only by the gateway over the
  # compose network — no host port. This sidecar holds the read-scoped token.
  mcp-vikunja:
    image: {{ agentgateway_docker_vikunja_mcp_image }}
    container_name: mcp-vikunja
    restart: {{ agentgateway_docker_restart_policy }}
    command:
      - "--stdio"
      - "npx -y @democratize-technology/vikunja-mcp@{{ agentgateway_docker_vikunja_mcp_version }}"
      - "--outputTransport"
      - "streamableHttp"
      - "--port"
      - "{{ agentgateway_docker_vikunja_mcp_port }}"
    environment:
      VIKUNJA_URL: "{{ agentgateway_docker_vikunja_url }}"
      VIKUNJA_API_TOKEN: "{{ agentgateway_docker_vikunja_read_token }}"
{% endif %}
{% if agentgateway_docker_qdrant_mcp_enabled | bool
      and agentgateway_docker_qdrant_api_key | length > 0 %}

  # Qdrant vector-memory MCP sidecar (see defaults). Reached only by the
  # gateway over the compose network — no host port published.
  mcp-qdrant:
    image: {{ agentgateway_docker_qdrant_mcp_image }}
    container_name: mcp-qdrant
    restart: {{ agentgateway_docker_restart_policy }}
    entrypoint: ["uvx"]
    command:
      - "mcp-server-qdrant=={{ agentgateway_docker_qdrant_mcp_version }}"
      - "--transport"
      - "streamable-http"
    environment:
      FASTMCP_SERVER_HOST: "0.0.0.0"
      FASTMCP_SERVER_PORT: "{{ agentgateway_docker_qdrant_mcp_port }}"
      QDRANT_URL: "{{ agentgateway_docker_qdrant_url }}"
      QDRANT_API_KEY: "{{ agentgateway_docker_qdrant_api_key }}"
      COLLECTION_NAME: "{{ agentgateway_docker_qdrant_mcp_collection }}"
    volumes:
      # Cache the uvx-resolved package + fastembed model across restarts.
      - mcp_qdrant_cache:/root/.cache
{% if agentgateway_docker_docs_mcp_enabled | bool %}

  # Docs-search MCP sidecar (see defaults) — FastMCP search_docs server that
  # embeds via the LLM router and searches Qdrant over REST (no local model).
  mcp-docs:
    image: {{ agentgateway_docker_qdrant_mcp_image }}
    container_name: mcp-docs
    restart: {{ agentgateway_docker_restart_policy }}
    entrypoint: ["uv"]
    command:
      - "run"
      - "--no-project"
      - "--with"
      - "fastmcp=={{ agentgateway_docker_docs_mcp_fastmcp_version }}"
      - "/app/mcp_docs_server.py"
    environment:
      FASTMCP_SERVER_HOST: "0.0.0.0"
      FASTMCP_SERVER_PORT: "{{ agentgateway_docker_docs_mcp_port }}"
      ROUTER_BASE_URL: "{{ agentgateway_docker_docs_mcp_router_base_url }}"
      ROUTER_API_KEY: "{{ agentgateway_docker_docs_mcp_router_api_key }}"
      EMBED_MODEL: "{{ agentgateway_docker_docs_mcp_embed_model }}"
      QDRANT_URL: "{{ agentgateway_docker_qdrant_url }}"
      QDRANT_API_KEY: "{{ agentgateway_docker_qdrant_api_key }}"
      COLLECTION_NAME: "{{ agentgateway_docker_docs_mcp_collection }}"
    volumes:
      - "{{ agentgateway_docker_data_dir }}/mcp_docs_server.py:/app/mcp_docs_server.py:ro"
      - mcp_qdrant_cache:/root/.cache
{% endif %}

volumes:
  mcp_qdrant_cache:
{% endif %}
