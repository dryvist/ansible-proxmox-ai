---
services:
  hindsight:
    image: {{ hindsight_docker_image }}
    container_name: {{ hindsight_docker_container_name }}
    restart: unless-stopped
    ports:
      - "{{ hindsight_docker_api_port }}:8888"
      - "{{ hindsight_docker_cp_port }}:9999"
    volumes:
      # Rebuildable cache only (downloaded local embedding model) — all real
      # state lives in the ai-VLAN Postgres cluster. Named volume, not a bind
      # mount: the image runs as the non-root `hindsight` user and a
      # root-owned bind mount breaks its ~/.cache writes (PermissionError on
      # huggingface token).
      - hindsight-cache:/home/hindsight/.cache
    environment:
      HINDSIGHT_API_DATABASE_URL: "postgresql://{{ hindsight_docker_db_user }}:{{ hindsight_docker_db_password }}@{{ hindsight_docker_db_host }}:{{ hindsight_docker_db_port }}/{{ hindsight_docker_db_name }}"
      HINDSIGHT_API_VECTOR_EXTENSION: pgvector
      HINDSIGHT_API_LLM_PROVIDER: openai
      HINDSIGHT_API_LLM_BASE_URL: "{{ hindsight_docker_llm_base_url }}"
      HINDSIGHT_API_LLM_MODEL: "{{ hindsight_docker_llm_model }}"
      HINDSIGHT_API_LLM_API_KEY: "{{ hindsight_docker_llm_api_key }}"
      HINDSIGHT_API_EMBEDDINGS_PROVIDER: "{{ hindsight_docker_embeddings_provider }}"
      # Stateless (POST-only) MCP: each request is self-contained, so the
      # Traefik-balanced two-replica pool needs no session affinity and a
      # replica can die mid-conversation without dropping a client's MCP
      # session. Stateful mode keeps per-replica in-memory sessions, which
      # round-robin across the pool and fail ~half of every session's calls
      # with "Session not found". POST-only drops server-initiated SSE, which
      # the retain/recall request/response tools do not use.
      HINDSIGHT_API_MCP_STATELESS: "{{ hindsight_docker_mcp_stateless | string | lower }}"
      HINDSIGHT_API_WORKER_ID: "{{ hindsight_docker_worker_id }}"
      HINDSIGHT_CP_ACCESS_KEY: "{{ hindsight_docker_cp_access_key }}"

volumes:
  hindsight-cache:
