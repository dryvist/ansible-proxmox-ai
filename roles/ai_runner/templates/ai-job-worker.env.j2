{{ ansible_managed | comment }}
# Environment for ai-job-worker. Rendered 0600, ai-runner-owned. Secrets are
# resolved bao-first (group_vars) with an env fallback (role defaults).

# --- Dispatch queue (Vikunja) ---
VIKUNJA_URL={{ ai_runner_vikunja_url }}
VIKUNJA_TOKEN={{ ai_runner_vikunja_token }}
AI_JOBS_PROJECT={{ ai_runner_vikunja_project }}
AI_RUNNER_PROFILE_LABEL={{ ai_runner_profile_label }}
POLL_INTERVAL_SECONDS={{ ai_runner_poll_interval_seconds }}
JOB_TIMEOUT_SECONDS={{ ai_runner_job_timeout_seconds }}

# --- Result push (ntfy) ---
NTFY_URL={{ ai_runner_ntfy_url }}

# --- Agent CLIs ---
CLAUDE_BIN={{ ai_runner_claude_bin }}
CODEX_BIN={{ ai_runner_codex_bin }}

# --- Model-provider API keys (third-party static; KV tier) ---
ANTHROPIC_API_KEY={{ ai_runner_anthropic_api_key }}
OPENAI_API_KEY={{ ai_runner_openai_api_key }}
